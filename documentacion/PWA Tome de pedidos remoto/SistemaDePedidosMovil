typescript// service-worker.ts

// 1. Guardar pedido offline
async function guardarPedidoLocal(pedido) {
  const db = await openDB('pedidos-db');
  const id = Date.now();
  
  await db.put('pedidos-pendientes', {
    id,
    ...pedido,
    sincronizado: false,
    creadoEn: new Date().toISOString()
  });
  
  return id;
}

// 2. Obtener pedidos no sincronizados
async function obtenerPedidosPendientes() {
  const db = await openDB('pedidos-db');
  return await db.getAll('pedidos-pendientes')
    .filter(p => !p.sincronizado);
}

// 3. Sincronizar cuando hay internet
async function sincronizarPedidos() {
  const pendientes = await obtenerPedidosPendientes();
  
  if (pendientes.length === 0) {
    return { success: true, enviados: 0 };
  }
  
  try {
    // Enviar a tu servidor a través de Cloudflare Tunnel
    const response = await fetch('https://sistema.tudominio.com/api/pedidos-pendientes/batch', {
      method: 'POST',
      headers: { 
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${token}`
      },
      body: JSON.stringify({ pedidos: pendientes })
    });
    
    if (response.ok) {
      // Marcar como sincronizados
      const db = await openDB('pedidos-db');
      for (const pedido of pendientes) {
        await db.put('pedidos-pendientes', {
          ...pedido,
          sincronizado: true,
          sincronizadoEn: new Date().toISOString()
        });
      }
      
      return { success: true, enviados: pendientes.length };
    }
  } catch (error) {
    console.error('Error sincronizando:', error);
    return { success: false, error };
  }
}

// 4. Auto-sincronizar cuando detecta internet
window.addEventListener('online', async () => {
  console.log('✅ Internet detectado, sincronizando...');
  const result = await sincronizarPedidos();
  
  if (result.success && result.enviados > 0) {
    mostrarNotificacion(`${result.enviados} pedidos sincronizados ✅`);
  }
});

