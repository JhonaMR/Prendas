javascript// controllers/pedidosPendientesController.js

/**
 * Recibir batch de pedidos desde vendedor
 * POST /api/pedidos-pendientes/batch
 */
const recibirBatchPedidos = async (req, res) => {
  const { pedidos } = req.body;
  const vendedor = req.user.loginCode; // Del JWT
  
  try {
    // Guardar cada pedido en PostgreSQL
    const ids = [];
    for (const pedido of pedidos) {
      const result = await query(`
        INSERT INTO pedidos_pendientes (
          id, vendedor_id, cliente_id, correria_id,
          items, total, fecha_inicio_despacho, fecha_fin_despacho,
          observaciones, estado, created_at
        ) VALUES (
          $1, $2, $3, $4, $5, $6, $7, $8, $9, 'pendiente', CURRENT_TIMESTAMP
        ) RETURNING id
      `, [
        generateId(),
        vendedor,
        pedido.clienteId,
        pedido.correriaId,
        JSON.stringify(pedido.items),
        pedido.total,
        pedido.fechaInicioDespacho,
        pedido.fechaFinDespacho,
        pedido.observaciones
      ]);
      
      ids.push(result.rows[0].id);
    }
    
    return res.json({
      success: true,
      message: `${pedidos.length} pedidos recibidos`,
      ids
    });
    
  } catch (error) {
    console.error('Error guardando pedidos:', error);
    return res.status(500).json({
      success: false,
      message: 'Error al guardar pedidos'
    });
  }
};
