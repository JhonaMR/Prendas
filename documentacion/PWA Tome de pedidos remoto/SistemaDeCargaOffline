Código en PWA (React)
// 1. CUANDO VENDEDOR LOGIN (CON INTERNET)

const handleLogin = async (loginCode: string, pin: string) => {
  try {
    // Enviar credenciales a backend
    const response = await fetch(
      'https://pedidos.tudominio.com/api/auth/login',
      {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ loginCode, pin })
      }
    );
    
    const result = await response.json();
    
    if (result.success) {
      // Guardar token y usuario
      localStorage.setItem('token', result.token);
      localStorage.setItem('usuario', JSON.stringify(result.usuario));
      
      // IMPORTANTE: Descargar datos maestros
      await descargarDatosMaestros(result.token);
      
      // Redirigir a home
      navigate('/home');
    }
  } catch (error) {
    console.error('Error login:', error);
  }
};

// 2. DESCARGAR DATOS MAESTROS

const descargarDatosMaestros = async (token: string) => {
  const db = await openDB();
  
  try {
    // Descargar clientes
    const clientesResponse = await fetch(
      'https://pedidos.tudominio.com/api/clientes',
      { headers: { 'Authorization': `Bearer ${token}` } }
    );
    const clientes = await clientesResponse.json();
    
    // Guardar en IndexedDB
    const tx = db.transaction(['clientes'], 'readwrite');
    const store = tx.objectStore('clientes');
    for (const cliente of clientes.data) {
      store.put(cliente);
    }
    
    // Descargar correrias
    const correriasResponse = await fetch(
      'https://pedidos.tudominio.com/api/correrias',
      { headers: { 'Authorization': `Bearer ${token}` } }
    );
    const correrias = await correriasResponse.json();
    
    // Guardar en IndexedDB
    const tx2 = db.transaction(['correrias'], 'readwrite');
    const store2 = tx2.objectStore('correrias');
    for (const correria of correrias.data) {
      store2.put(correria);
    }
    
    // Descargar referencias
    const referenciasResponse = await fetch(
      'https://pedidos.tudominio.com/api/referencias',
      { headers: { 'Authorization': `Bearer ${token}` } }
    );
    const referencias = await referenciasResponse.json();
    
    // Guardar en IndexedDB
    const tx3 = db.transaction(['referencias'], 'readwrite');
    const store3 = tx3.objectStore('referencias');
    for (const ref of referencias.data) {
      store3.put(ref);
    }
    
    console.log('✅ Datos maestros descargados');
  } catch (error) {
    console.error('Error descargando datos:', error);
  }
};

// 3. CUANDO VENDEDOR ABRE FORMULARIO (OFFLINE)

const handleTomarPedido = async () => {
  const db = await openDB();
  
  // Obtener clientes de IndexedDB (NO del servidor)
  const clientesResponse = await db.getAll('clientes');
  setClientes(clientesResponse);
  
  // Obtener correrias de IndexedDB (NO del servidor)
  const correriasResponse = await db.getAll('correrias');
  setCorrerias(correriasResponse);
};

// 4. CUANDO SELECCIONA CORRERÍA (OFFLINE)

const handleCorreriaChange = async (correriaId: string) => {
  const db = await openDB();
  
  // Obtener referencias de esa correría de IndexedDB
  const tx = db.transaction(['referencias'], 'readonly');
  const store = tx.objectStore('referencias');
  const index = store.index('correriaId');
  
  const referencias = await index.getAll(correriaId);
  setReferenciasDisponibles(referencias);
};

// 5. GUARDAR PEDIDO (OFFLINE)

const handleGuardarPedido = async (formData) => {
  const db = await openDB();
  
  const pedido = {
    id: generateUUID(),
    clienteId: formData.clienteId,
    correriaId: formData.correriaId,
    items: formData.items,
    total: formData.total,
    fechaInicioDespacho: formData.fechaInicio,
    fechaFinDespacho: formData.fechaFin,
    observaciones: formData.observaciones,
    sincronizado: false,
    createdAt: new Date().toISOString()
  };
  
  // Guardar en IndexedDB
  const tx = db.transaction(['pedidos'], 'readwrite');
  const store = tx.objectStore('pedidos');
  await store.add(pedido);
  
  showNotification('✅ Pedido guardado localmente');
};
🌐 CUANDO VUELVE INTERNET
Vendedor llega a zona con WiFi
   ↓
PWA detecta: window.addEventListener('online')
   ↓
Automáticamente sincroniza:

1. Obtiene pedidos no sincronizados de IndexedDB
   SELECT * FROM pedidos WHERE sincronizado = false
   ↓
   Encuentra: 3 pedidos

2. Prepara batch
   {
     pedidos: [
       { clienteId: "cliente_123", items: [...] },
       { clienteId: "cliente_456", items: [...] },
       { clienteId: "cliente_789", items: [...] }
     ]
   }

3. Envía a servidor
   POST /api/pedidos-pendientes/batch
   ↓
   Cloudflare Tunnel → Tu servidor

4. Backend procesa
   - Valida datos
   - Guarda en PostgreSQL
   - Retorna: 200 OK

5. PWA marca como sincronizados
   UPDATE pedidos SET sincronizado = true
   ↓
   ✅ Confirmación: "3 pedidos sincronizados"
