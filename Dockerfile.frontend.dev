# Dockerfile para desarrollo con hot-reload
FROM node:20-alpine

WORKDIR /app

# Instalar dumb-init
RUN apk add --no-cache dumb-init

# Copiar package files
COPY package*.json ./

# Instalar dependencias
RUN npm ci

# Copiar código fuente
COPY . .

# Exponer puerto
EXPOSE 5173

# Usar dumb-init para manejar signals
ENTRYPOINT ["dumb-init", "--"]

# Comando por defecto - Vite dev server
CMD ["npm", "run", "dev"]
