# ============================================
# 🐳 CONFIGURACIÓN PRODUCCIÓN - EJEMPLO
# ============================================
# Copia este archivo a backend/.env para usar en producción

# ============================================
# ENTORNO
# ============================================
NODE_ENV=production
LOG_LEVEL=warn

# ============================================
# SEGURIDAD - JWT
# ============================================
# ⚠️ CRÍTICO: Genera un secreto seguro ÚNICO
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REEMPLAZA_CON_UN_SECRETO_UNICO_Y_SEGURO_DE_64_CARACTERES
JWT_EXPIRES_IN=24h

# ============================================
# BASE DE DATOS - POSTGRESQL
# ============================================
# ⚠️ CRÍTICO: Usa contraseña fuerte
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=REEMPLAZA_CON_CONTRASEÑA_FUERTE_MINIMO_16_CARACTERES
DB_NAME=inventory

# ============================================
# CONNECTION POOL
# ============================================
DB_POOL_MIN=10
DB_POOL_MAX=30
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000
DB_SSL=true

# ============================================
# CORS - Dominios permitidos
# ============================================
# Reemplaza con tus dominios reales
CORS_ORIGIN=https://tu-dominio.com,https://www.tu-dominio.com

# ============================================
# NOTAS IMPORTANTES
# ============================================
# 1. NUNCA uses valores por defecto en producción
# 2. Genera JWT_SECRET único y seguro
# 3. Usa contraseña fuerte para DB_PASSWORD
# 4. Usa HTTPS en CORS_ORIGIN
# 5. Configura un reverse proxy (Nginx/Apache)
# 6. Haz backups regulares de la BD
# 7. Monitorea los logs regularmente
# 8. Usa certificados SSL válidos
