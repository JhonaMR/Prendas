# ============================================
# 🐳 CONFIGURACIÓN DOCKER - EJEMPLO
# ============================================
# Copia este archivo a backend/.env para usar con Docker

# ============================================
# ENTORNO
# ============================================
NODE_ENV=production
LOG_LEVEL=info

# ============================================
# SEGURIDAD - JWT
# ============================================
# Genera un secreto seguro con:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=tu_secreto_super_seguro_cambialo_123456
JWT_EXPIRES_IN=24h

# ============================================
# BASE DE DATOS - POSTGRESQL (Docker)
# ============================================
# En Docker, el host es el nombre del servicio: "postgres"
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=inventory

# ============================================
# CONNECTION POOL
# ============================================
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000
DB_SSL=false

# ============================================
# CORS - Ajusta según tu entorno
# ============================================
# Para desarrollo local:
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:5173

# Para producción (reemplaza con tu dominio):
# CORS_ORIGIN=https://tu-dominio.com,https://www.tu-dominio.com

# ============================================
# NOTAS IMPORTANTES
# ============================================
# 1. En Docker, DB_HOST debe ser "postgres" (nombre del servicio)
# 2. Cambia JWT_SECRET en producción
# 3. Cambia DB_PASSWORD en producción
# 4. Usa DB_SSL=true en producción
# 5. Actualiza CORS_ORIGIN con tus dominios reales
